0ac7d-9f03-4ff8-920f-1789e34bdbd5" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--header-height)" dir="auto" data-turn-id="42e0ac7d-9f03-4ff8-920f-1789e34bdbd5" data-turn-id-container="42e0ac7d-9f03-4ff8-920f-1789e34bdbd5" data-testid="conversation-turn-573" data-scroll-anchor="false" data-turn="user"><h4 class="sr-only select-none">You said:</h4><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="42e0ac7d-9f03-4ff8-920f-1789e34bdbd5" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 overflow-hidden rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="max-w-full min-w-0 [overflow-wrap:anywhere] whitespace-pre-wrap">this is good but copilot can make so many mistakes with this , I need you to give clear instructiosn for a percefect homepage and u must do the thinkings intead of copliot</div></div></div></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Share prompt" data-testid="share-prompt-link-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#630ca2" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Edit message" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></section></div><div class="" data-turn-id-container="2a61e762-be65-4c58-9d8d-749775bf89b7" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="2a61e762-be65-4c58-9d8d-749775bf89b7" data-turn-id-container="2a61e762-be65-4c58-9d8d-749775bf89b7" data-testid="conversation-turn-574" data-scroll-anchor="false" data-turn="assistant"><h4 class="sr-only select-none">ChatGPT said:</h4><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div class="flex items-center justify-between"><button type="button" class="text-token-text-tertiary hover:text-token-text-primary dark:hover:text-token-text-primary flex items-center gap-0.5 text-start dark:text-(--interactive-label-tertiary-default)">Thought for 33s<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="icon-xs"><use href="/cdn/assets/sprites-core-0a715c44.svg#b140e7" fill="currentColor"></use></svg></button></div><div data-message-author-role="assistant" data-message-id="ff079942-e7d1-4908-b90a-857eebe14e49" dir="auto" data-message-model-slug="gpt-5-5-thinking" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full light markdown-new-styling"><p data-start="0" data-end="226">Yes — you’re right. Copilot should <strong data-start="35" data-end="42">not</strong> be asked to “make it better” because then it improvises and breaks things. You need a <strong data-start="129" data-end="164">strict implementation blueprint</strong> where Copilot is mostly just coding exactly what we designed.</p>
<p data-start="228" data-end="316">Use this as the <strong data-start="244" data-end="268">single master prompt</strong> for the homepage. It is intentionally specific.</p>
<hr data-start="318" data-end="321">
<pre class="overflow-visible! px-0!" data-start="323" data-end="15626"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-0a715c44.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>You are GitHub Copilot Agent working on the Shift Panic web game.</span><br><br><span>IMPORTANT:</span><br><span>Do NOT be creative beyond this prompt. Do NOT redesign randomly. Do NOT change gameplay logic. Do NOT reset user progress. Do NOT rewrite the entire app. Your job is to implement the exact homepage layout and behavior described below.</span><br><br><span>The current homepage looks too empty and unprofessional. I want a polished desktop-first Poki-quality homepage inspired by the energy of Brawl Stars, Subway Surfers, Geometry Dash, and Poki game menus, but using original Shift Panic visuals only.</span><br><br><span>Do not use copyrighted art or copied layouts. Use the existing Shift Panic visual identity: purple/pink/blue gradients, glowing blocks, neon orb, coins, skins, challenges, and panic/dodge gameplay.</span><br><br><span>==================================================</span><br><span>ABSOLUTE RULES</span><br><span>==================================================</span><br><br><span>1. Preserve all existing saved data:</span><br><span>   - coins</span><br><span>   - best score</span><br><span>   - lifetime score</span><br><span>   - unlocked skins</span><br><span>   - equipped skin</span><br><span>   - abilities</span><br><span>   - powerups</span><br><span>   - challenge progress</span><br><span>   - Panic Quest progress</span><br><span>   - leaderboard data</span><br><span>   - localStorage data</span><br><span>   - Firebase data</span><br><br><span>2. Do not rename or delete existing storage keys unless you add a backward-compatible migration.</span><br><br><span>3. Do not change core gameplay in this prompt.</span><br><br><span>4. Do not break:</span><br><span>   - Endless mode</span><br><span>   - Panic Quest button</span><br><span>   - Shop button</span><br><span>   - Leaderboard button</span><br><span>   - Help button</span><br><span>   - Settings button</span><br><span>   - Game Over screen</span><br><span>   - existing keyboard controls</span><br><span>   - existing mouse/touch controls</span><br><br><span>5. Do not add dead buttons. Every button must call an existing working function or route.</span><br><br><span>6. Do not create duplicate event listeners.</span><br><br><span>7. Do not create multiple animation intervals every time the user returns to home.</span><br><br><span>8. Do not allow black screens. If something fails, show the homepage anyway.</span><br><br><span>9. Homepage must be desktop-first. Optimize for 1920x1080, 1600x900, and 1366x768.</span><br><br><span>10. The primary homepage content must fit above the fold on desktop. The user should not need to scroll to see Play Endless, Panic Quest, Shop, Leaderboard, Help, best score, coins, and daily challenge.</span><br><br><span>==================================================</span><br><span>FINAL HOMEPAGE STRUCTURE</span><br><span>==================================================</span><br><br><span>Build the homepage as one professional arcade lobby.</span><br><br><span>The page should have these exact visual sections:</span><br><br><span>A. FULL-SCREEN BACKGROUND</span><br><span>B. CENTER MAIN LOBBY PANEL</span><br><span>C. LEFT PLAYER/PREVIEW AREA</span><br><span>D. RIGHT ACTION/PROGRESSION AREA</span><br><span>E. TOP STATUS BAR INSIDE PANEL</span><br><span>F. MAIN CTA BUTTONS</span><br><span>G. DAILY CHALLENGE CARD</span><br><span>H. BOTTOM NAVIGATION ROW</span><br><br><span>Do not make the homepage a long vertical stack anymore.</span><br><br><span>==================================================</span><br><span>A. FULL-SCREEN BACKGROUND</span><br><span>==================================================</span><br><br><span>Use the current purple arcade background, but polish it.</span><br><br><span>Background requirements:</span><br><span>1. Dark purple radial gradient base.</span><br><span>2. Floating colorful blocks in the background.</span><br><span>3. Blocks should be blurred and lower opacity behind the main panel.</span><br><span>4. Add subtle depth:</span><br><span>   - tiny far particles</span><br><span>   - medium glowing blocks</span><br><span>   - a few larger blurred blocks</span><br><span>5. Do NOT let background blocks cover text.</span><br><span>6. Add a soft spotlight glow behind the main lobby panel.</span><br><span>7. Background should look animated but not chaotic.</span><br><span>8. If animations already exist, reuse and clean them instead of creating a second competing system.</span><br><br><span>Do not make the page plain black.</span><br><br><span>==================================================</span><br><span>B. CENTER MAIN LOBBY PANEL</span><br><span>==================================================</span><br><br><span>Create one main centered panel.</span><br><br><span>Desktop sizing:</span><br><span>- Width: around 1000px to 1150px.</span><br><span>- Max-width: about 86vw.</span><br><span>- Height: should fit inside viewport.</span><br><span>- Use min-height only if needed.</span><br><span>- Panel should be centered horizontally.</span><br><span>- Panel should start near the vertical center but slightly above center.</span><br><br><span>Panel style:</span><br><span>- Dark glass background.</span><br><span>- Rounded corners: 28px to 36px.</span><br><span>- Border: subtle purple/blue border.</span><br><span>- Shadow: large soft purple glow.</span><br><span>- Add very subtle inner shine.</span><br><span>- Use backdrop blur if already safe.</span><br><span>- The panel should feel like a premium game lobby.</span><br><br><span>Important:</span><br><span>The homepage should NOT look like disconnected floating cards. The panel should visually hold everything together.</span><br><br><span>==================================================</span><br><span>C. TOP STATUS BAR INSIDE PANEL</span><br><span>==================================================</span><br><br><span>At the top of the panel, create a compact status bar.</span><br><br><span>Left side:</span><br><span>- Shift Panic small logo/title or icon.</span><br><span>- Small subtitle: “Dodge the forbidden color. Survive the panic.”</span><br><br><span>Right side:</span><br><span>- Best score pill</span><br><span>- Coins pill</span><br><span>- Rank pill or Lifetime score pill</span><br><span>- Settings button</span><br><br><span>Style:</span><br><span>- Pills should be compact, colorful, and readable.</span><br><span>- Coins should have gold styling.</span><br><span>- Best score should have purple/blue styling.</span><br><span>- Settings should remain top-right and clickable.</span><br><br><span>Do not put huge stats above the title anymore.</span><br><br><span>==================================================</span><br><span>D. MAIN HERO AREA</span><br><span>==================================================</span><br><br><span>Inside the panel, create a 2-column desktop layout.</span><br><br><span>Left column: game identity / mascot / preview.</span><br><span>Right column: actions / progression / daily challenge.</span><br><br><span>Approximate layout:</span><br><span>- Left column: 42%</span><br><span>- Right column: 58%</span><br><span>- Gap: 28px to 40px</span><br><br><span>On smaller desktop widths, allow stacking only if necessary.</span><br><br><span>==================================================</span><br><span>E. LEFT PLAYER/PREVIEW AREA</span><br><span>==================================================</span><br><br><span>The left side should make the game visually understandable.</span><br><br><span>Add a large “Panic Orb” preview:</span><br><span>1. Show the player orb large, around 130–170px.</span><br><span>2. It should glow.</span><br><span>3. It should have a subtle idle float animation.</span><br><span>4. It can have simple original eyes/expression if easy and safe.</span><br><span>5. Do not change actual gameplay collision or player code.</span><br><br><span>Below or around the orb, show a mini gameplay preview box:</span><br><span>1. Small fake preview scene, not real gameplay logic.</span><br><span>2. Show:</span><br><span>   - tiny player orb</span><br><span>   - falling blocks</span><br><span>   - forbidden color label</span><br><span>   - a few coins</span><br><span>   - “Near miss!” or “Combo!” micro text occasionally</span><br><span>3. This preview must be visual only.</span><br><span>4. It must not affect real score, coins, player movement, enemies, or game state.</span><br><span>5. It must clean itself up when leaving home.</span><br><span>6. Do not use setInterval repeatedly without cleanup.</span><br><br><span>If a preview system is risky, use CSS animations only.</span><br><br><span>Left side text:</span><br><span>- Big title: “Shift Panic”</span><br><span>- Subtitle: “Avoid the forbidden color before it switches.”</span><br><span>- Three small chips:</span><br><span>  - Fast Reflexes</span><br><span>  - Color Switching</span><br><span>  - Unlock Skins</span><br><br><span>The title should be big but not so huge that it gets cut off.</span><br><br><span>==================================================</span><br><span>F. RIGHT ACTION AREA</span><br><span>==================================================</span><br><br><span>This is the most important part.</span><br><br><span>The Play button must dominate.</span><br><br><span>Primary CTA:</span><br><span>- Huge button text: “PLAY ENDLESS”</span><br><span>- Big enough that it is obviously the main action.</span><br><span>- Use pink/purple/orange gradient.</span><br><span>- Add glow.</span><br><span>- Add hover scale.</span><br><span>- Add click press animation.</span><br><span>- Add subtle pulse every few seconds.</span><br><span>- Should call the existing Endless mode start function.</span><br><br><span>Secondary CTA:</span><br><span>- Button text: “PANIC QUEST”</span><br><span>- Blue/cyan/purple gradient.</span><br><span>- Add small “NEW” or “QUEST” badge.</span><br><span>- Should call existing Panic Quest navigation.</span><br><span>- Do not break it.</span><br><span>- If Panic Quest currently has bugs, do not hide the button. Keep the route working.</span><br><br><span>Button layout:</span><br><span>- Play Endless full-width.</span><br><span>- Panic Quest full-width under it.</span><br><span>- Buttons should be large, arcade-like, and readable.</span><br><br><span>Do not add unnecessary text between the buttons.</span><br><br><span>==================================================</span><br><span>G. DAILY CHALLENGE CARD</span><br><span>==================================================</span><br><br><span>Place Daily Challenge above or below the main buttons in the right column.</span><br><br><span>Card content:</span><br><span>- Header: “DAILY CHALLENGE”</span><br><span>- Current challenge title</span><br><span>- Objective</span><br><span>- Reward coins</span><br><span>- Time remaining</span><br><span>- Progress if available</span><br><span>- Button:</span><br><span>  - “PLAY DAILY” if not complete</span><br><span>  - “CLAIM” if complete and claimable</span><br><span>  - “COMPLETED” if already claimed</span><br><br><span>Style:</span><br><span>- Bright border, maybe pink/gold.</span><br><span>- Slight glow.</span><br><span>- Small reward coin icon.</span><br><span>- Should look valuable.</span><br><br><span>Important:</span><br><span>Do not allow duplicate reward claiming.</span><br><span>Do not reset daily challenge progress.</span><br><span>Do not create fake claim state.</span><br><br><span>==================================================</span><br><span>H. PROGRESSION PREVIEW CARD</span><br><span>==================================================</span><br><br><span>Add a compact progression card in the right column or below the buttons.</span><br><br><span>Content:</span><br><span>- “Next Unlock”</span><br><span>- Lifetime score progress bar</span><br><span>- Current lifetime score</span><br><span>- Next reward text</span><br><span>- Rank label</span><br><br><span>Example:</span><br><span>“Next Reward: 100 Coins”</span><br><span>“221,925 / 250,000 Lifetime Score”</span><br><span>“Rank: Panic Rookie”</span><br><br><span>Style:</span><br><span>- Clean and compact.</span><br><span>- Progress bar should be colorful.</span><br><span>- This should not overpower the Play button.</span><br><br><span>Important:</span><br><span>Read from existing data. Do not reset or rewrite data.</span><br><br><span>==================================================</span><br><span>I. BOTTOM NAVIGATION ROW</span><br><span>==================================================</span><br><br><span>At the bottom of the main panel, add a clean button row.</span><br><br><span>Buttons:</span><br><span>1. Multiplayer</span><br><span>2. Shop</span><br><span>3. Leaderboard</span><br><span>4. Help</span><br><br><span>Style:</span><br><span>- All same height.</span><br><span>- Rounded.</span><br><span>- Icon + text.</span><br><span>- Hover glow.</span><br><span>- Active click feedback.</span><br><span>- If Multiplayer is unfinished, add small “BETA” badge, but button should still route correctly if it already exists.</span><br><br><span>Do not place these below the browser fold on desktop.</span><br><br><span>==================================================</span><br><span>EXACT VISUAL HIERARCHY</span><br><span>==================================================</span><br><br><span>The player should notice things in this order:</span><br><br><span>1. Shift Panic title / mascot</span><br><span>2. PLAY ENDLESS button</span><br><span>3. Panic Quest button</span><br><span>4. Daily Challenge</span><br><span>5. Coins / best score</span><br><span>6. Shop / Leaderboard / Help</span><br><br><span>If anything else is visually louder than Play Endless, reduce it.</span><br><br><span>==================================================</span><br><span>SPACING REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Fix the current issue where the homepage feels too tall or awkward.</span><br><br><span>Use:</span><br><span>- consistent spacing</span><br><span>- no massive empty gaps</span><br><span>- no cards floating randomly far away</span><br><span>- no giant blank right side</span><br><span>- no title cut off</span><br><span>- no buttons below the fold</span><br><br><span>Desktop target:</span><br><span>At 1920x1080, the full lobby panel should be visible without scrolling.</span><br><br><span>At 1366x768:</span><br><span>- title visible</span><br><span>- Play Endless visible</span><br><span>- Panic Quest visible</span><br><span>- bottom nav visible or almost visible</span><br><span>- no important item should be unreachable</span><br><br><span>==================================================</span><br><span>TYPOGRAPHY</span><br><span>==================================================</span><br><br><span>Use bold arcade-style typography, but keep it readable.</span><br><br><span>Rules:</span><br><span>1. Main title large and bold.</span><br><span>2. Button text all caps.</span><br><span>3. Avoid tiny gray text.</span><br><span>4. Improve contrast.</span><br><span>5. No long paragraphs on homepage.</span><br><span>6. Use short phrases only.</span><br><br><span>Homepage copy should be:</span><br><br><span>Title:</span><br><span>Shift Panic</span><br><br><span>Subtitle:</span><br><span>Dodge the forbidden color. Survive the panic.</span><br><br><span>Feature chips:</span><br><span>Fast Reflexes</span><br><span>Color Switching</span><br><span>Unlock Skins</span><br><br><span>Play button:</span><br><span>PLAY ENDLESS</span><br><br><span>Quest button:</span><br><span>PANIC QUEST</span><br><br><span>Daily:</span><br><span>DAILY CHALLENGE</span><br><br><span>Bottom:</span><br><span>Multiplayer</span><br><span>Shop</span><br><span>Leaderboard</span><br><span>Help</span><br><br><span>==================================================</span><br><span>BUG PREVENTION REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Before editing, inspect how current homepage state and navigation are implemented.</span><br><br><span>Specifically check:</span><br><span>1. How Endless mode starts.</span><br><span>2. How Panic Quest opens.</span><br><span>3. How Shop opens.</span><br><span>4. How Leaderboard opens.</span><br><span>5. How Help opens.</span><br><span>6. How Settings opens.</span><br><span>7. How coins/best/lifetime/rank are loaded.</span><br><span>8. Whether homepage renders through one main function or multiple duplicated sections.</span><br><span>9. Whether the background animation is shared with gameplay.</span><br><br><span>Then make minimal safe edits.</span><br><br><span>Do not duplicate the entire homepage code if there is already a renderHome/renderMenu function. Modify the existing one.</span><br><br><span>If the homepage is built from DOM strings, update the string carefully.</span><br><span>If the homepage is built from JS-created elements, update the builder carefully.</span><br><span>If CSS controls most layout, prefer CSS changes where possible.</span><br><br><span>==================================================</span><br><span>EVENT HANDLER REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Every button must use existing functions.</span><br><br><span>Do not invent fake functions unless necessary.</span><br><span>If a needed function does not exist, create a tiny wrapper that calls the correct existing state transition.</span><br><br><span>Button mappings:</span><br><span>- PLAY ENDLESS: start existing endless mode</span><br><span>- PANIC QUEST: open existing Panic Quest / Shift Trials screen</span><br><span>- SHOP: open existing shop</span><br><span>- LEADERBOARD: open existing leaderboard</span><br><span>- HELP: open existing help</span><br><span>- SETTINGS: open existing settings</span><br><span>- MULTIPLAYER: open existing multiplayer if available</span><br><br><span>After adding buttons, test clicks.</span><br><br><span>==================================================</span><br><span>DATA SAFETY REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Do not clear localStorage.</span><br><br><span>Do not overwrite existing data with defaults.</span><br><br><span>Safe pattern:</span><br><span>- Read saved value.</span><br><span>- If missing, display default.</span><br><span>- Never write default over existing value unless the user earns/changes something.</span><br><br><span>If parsing saved data fails:</span><br><span>- catch the error</span><br><span>- show safe display</span><br><span>- do not crash homepage</span><br><span>- do not erase stored data</span><br><br><span>==================================================</span><br><span>RESPONSIVE REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Desktop first:</span><br><span>- 1920x1080</span><br><span>- 1600x900</span><br><span>- 1366x768</span><br><br><span>Mobile can be acceptable but not the focus in this prompt.</span><br><br><span>Use CSS media queries:</span><br><span>- Above 900px: 2-column lobby layout.</span><br><span>- Below 900px: stack layout.</span><br><span>- Below 600px: buttons full width.</span><br><br><span>Do not break mobile completely, but desktop is priority.</span><br><br><span>==================================================</span><br><span>PERFORMANCE REQUIREMENTS</span><br><span>==================================================</span><br><br><span>Do not use heavy animations everywhere.</span><br><br><span>Safe animations:</span><br><span>- transform</span><br><span>- opacity</span><br><span>- filter sparingly</span><br><br><span>Avoid:</span><br><span>- layout-thrashing JS animations</span><br><span>- huge DOM object counts</span><br><span>- many setIntervals</span><br><span>- unbounded requestAnimationFrame loops</span><br><span>- canvas if not already used safely</span><br><br><span>If using requestAnimationFrame, make sure it stops when not on homepage.</span><br><br><span>==================================================</span><br><span>QUALITY BAR</span><br><span>==================================================</span><br><br><span>The final homepage should feel:</span><br><span>- polished</span><br><span>- colorful</span><br><span>- arcade-like</span><br><span>- inviting</span><br><span>- professional</span><br><span>- not empty</span><br><span>- not cluttered</span><br><span>- not generic</span><br><span>- clearly clickable</span><br><span>- ready for a Poki-style review</span><br><br><span>It should NOT feel:</span><br><span>- like a school project</span><br><span>- like plain HTML cards</span><br><span>- like random stacked boxes</span><br><span>- like a long settings page</span><br><span>- like a static landing page</span><br><span>- like a broken prototype</span><br><br><span>==================================================</span><br><span>FINAL ACCEPTANCE TEST</span><br><span>==================================================</span><br><br><span>After implementation, perform and fix anything that fails:</span><br><br><span>1. Hard refresh the site.</span><br><span>2. Homepage loads with no black screen.</span><br><span>3. Console has no red errors.</span><br><span>4. Existing coins show correctly.</span><br><span>5. Existing best score shows correctly.</span><br><span>6. Existing lifetime score shows correctly.</span><br><span>7. PLAY ENDLESS starts game.</span><br><span>8. Player can move in game.</span><br><span>9. Blocks spawn in game.</span><br><span>10. Score increases.</span><br><span>11. Game Over appears when player dies.</span><br><span>12. Home button returns to homepage.</span><br><span>13. Panic Quest button opens Panic Quest screen.</span><br><span>14. Shop button opens Shop.</span><br><span>15. Leaderboard button opens Leaderboard.</span><br><span>16. Help button opens Help.</span><br><span>17. Settings opens.</span><br><span>18. Refresh again and verify progress is still saved.</span><br><span>19. At 1920x1080, main homepage content fits without scrolling.</span><br><span>20. At 1366x768, Play buttons are still visible and usable.</span><br><br><span>If any of these fail, fix them before finishing.</span><br><br><span>Do not stop after visual changes. The homepage must work.</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="15628" data-end="15631">
<p data-start="15633" data-end="15722">This is the better way to do it: <strong data-start="15666" data-end="15699">one strict homepage blueprint</strong>, not 20 vague prompts.</p>
<p data-start="15724" data-end="15982" data-is-last-node="" data-is-only-node="">My recommendation: queue <strong data-start="15749" data-end="15779">only this one prompt first</strong>. Do <strong data-start="15784" data-end="15791">not</strong> add more homepage prompts until you see what it produces. If it still looks wrong, send me the screenshot and I’ll generate a second prompt that says exactly what to fix based on the result.</p></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#51753c" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Bad response" aria-pressed="false" data-testid="bad-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#2126ae" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Share" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#630ca2" fill="currentColor"></use></svg></span></button><span class="" data-state="closed"><button type="button" id="radix-_r_10j_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="cursor-pointer touch:px-2.5 text-token-text-secondary hover:bg-token-bg-secondary h-[30px] rounded-md px-1.5" aria-label="Switch model"><div class="flex items-center"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#ec66f0" fill="currentColor"></use></svg></div></button></span><button class="text-token-text-secondary hover:bg-token-bg-secondary touch:w-10 flex h-8 w-8 items-center justify-center rounded-lg" aria-label="More actions" type="button" id="radix-_r_d4_" aria-haspopup="menu" aria-expanded="false" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-0a715c44.svg#f6d0e2" fill="currentColor"></use></svg></button></div></div></div></div><span class="sr-only"><br></span></section></div><div class="" data-turn-id-container="55120e2b-31b9-4cc6-9983-df3b3d34829f" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--header-height)" dir="auto" data-turn-id="55120e2b-31b9-4cc6-9983-df3b3d34829f" data-turn-id-container="55120e2b-31b9-4cc6-9983-df3b3d34829f" data-testid="conversation-turn-575" data-scroll-anchor="false" data-turn="user"><h4 class="sr-only select-none">You said:</h4><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="55120e2b-31b9-4cc6-9983-df3b3d34829f" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="flex w-[var(--user-chat-width,70%)] flex-col items-end"><div class="flex flex-row items-center justify-end gap-1"><div class="overflow-hidden rounded-[1.75rem] w-full h-full max-w-96 max-h-64"><div class="group/message-image bg-token-main-surface-secondary text-token-text-tertiary relative flex h-auto w-full max-w-lg items-center justify-center overflow-hidden"><button type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="radix-_r_ms_" data-state="closed" class="overflow-hidden rounded-[1.75rem] w-full h-full max-w-96 max-h-64" aria-label="Open image: image(153).png"><img alt="image(153).png" width="1920" height="1080" loading="lazy" decoding="async" class="max-w-full object-cover object-center overflow-hidden rounded-[1.75rem] w-full h-full max-w-96 max-h-64 w-fit transition-opacity duration-300 opacity-100" src="./shiftpanic-home-hero_files/image(153).png"></button></div></div></div></div><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 overflow-hidden rounded-[22px] px-4 py-2.5 leading-6 rounded-se-lg max-w-(--user-chat-width,70%)"><div class="max-w-full min-w-0 [overflow-wrap:anywhere] whitespace-pre-wrap">this is the final proudct after the changes , I feel like there is too much text and there is not enough color , also what images should i ask you to generate and add to the code to enhance the game </div></div></div></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn